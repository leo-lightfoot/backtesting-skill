{
  "_description": "Trend Dip Buy strategy — grid search with out-of-sample validation. Sweeps MA periods and entry conditions; tests best combo on hold-out data from 2023 onward.",

  "template": "trend_dip_buy_long_only",
  "symbols": ["QQQ"],
  "frequency": "daily",
  "start": "2018-01-02",
  "end": "2026-03-10",
  "initial_cash": 100000,

  "strategy": {
    "fast_ma": 10,
    "medium_ma": 20,
    "slow_ma": 50,
    "entry_on": "fast",
    "exit_below": "medium"
  },

  "advanced": {
    "benchmark": "QQQ",
    "allow_yahoo_ingest": true,
    "min_price": 5.0,
    "min_daily_volume": 2000000,
    "slope_lookback": 5,
    "bounce_range_ratio": 0.5,

    "execution": {
      "slippage_bps": 5.0,
      "commission_per_share": 0.001
    },

    "grid_search": {
      "enabled": true,
      "rank_by": "sharpe",
      "top_n": 5,
      "params": {
        "fast_ma": [8, 10],
        "medium_ma": [20],
        "slope_lookback": [3, 5],
        "bounce_range_ratio": [0.45, 0.55],
        "entry_on": ["fast", "medium"],
        "exit_below": ["medium"]
      }
    },

    "validation_split": {
      "enabled": true,
      "method": "date",
      "split_date": "2023-01-03",
      "gap_bars": 0,
      "rank_on": "test_sharpe"
    }
  }
}
